# Athena Environment Configuration
# Copy this file to .env and fill in your values

# Ollama Configuration
ATHENA_OLLAMA_BASE_URL=http://localhost:11434
ATHENA_OLLAMA_DEFAULT_MODEL=qwen2.5:7b
ATHENA_OLLAMA_FAST_MODEL=qwen2.5:1.5b

# GitHub Integration (optional)
ATHENA_GITHUB_TOKEN=

# Telegram Notifications (optional)
ATHENA_TELEGRAM_BOT_TOKEN=
ATHENA_TELEGRAM_CHAT_ID=

# Database
ATHENA_DB_PATH=data/athena.db

# Log Level: DEBUG, INFO, WARNING, ERROR
ATHENA_LOG_LEVEL=INFO
